@model Lab_2_DB.Models.KovinioSportoSaleF2
@{
    ViewBag.Title = "Redaguoti salę";
}

<h2>Redaguoti sporto salę</h2>

<form asp-action="Edit" asp-route-id="@Model.Sale.OriginalPK" method="post">
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

    <div class="form-group">
        <label asp-for="Sale.KluboPavadinimas"></label>
        <input asp-for="Sale.KluboPavadinimas" class="form-control" />
        <span asp-validation-for="Sale.KluboPavadinimas" class="text-danger"></span>
    </div>
    <div class="form-group">
        <label asp-for="Sale.Miestas"></label>
        <input asp-for="Sale.Miestas" class="form-control" />
        <span asp-validation-for="Sale.Miestas" class="text-danger"></span>
    </div>
    <div class="form-group">
        <label asp-for="Sale.Salis"></label>
        <input asp-for="Sale.Salis" class="form-control" />
        <span asp-validation-for="Sale.Salis" class="text-danger"></span>
    </div>
    <div class="form-group">
        <label asp-for="Sale.Adresas"></label>
        <input asp-for="Sale.Adresas" class="form-control" />
        <span asp-validation-for="Sale.Adresas" class="text-danger"></span>
    </div>
    <div class="form-group">
        <label asp-for="Sale.TelefonoNr"></label>
        <input asp-for="Sale.TelefonoNr" class="form-control" />
        <span asp-validation-for="Sale.TelefonoNr" class="text-danger"></span>
    </div>

    <hr />
    <h4>Priskirti trenerį šiai salei</h4>
    <div class="form-group">
        <label asp-for="PasirinktasTrenerisId">Treneris</label>
        <select asp-for="PasirinktasTrenerisId" asp-items="Model.TreneriaiPasirinkimui" class="form-control">
            <option value="">-- Pasirinkite trenerį --</option>
        </select>
        <span asp-validation-for="PasirinktasTrenerisId" class="text-danger"></span>
    </div>
    <button type="submit" name="actionType" value="assign" class="btn btn-outline-primary">Priskirti trenerį</button>

    <div class="mt-3">
        <h5>Šiai salei priskirti treneriai</h5>
        @if (Model.PriskirtiTreneriai.Count > 0)
        {
            <table class="table table-sm table-striped">
                <thead>
                    <tr>
                        <th>ID</th>
                        <th>Vardas</th>
                        <th>Pavardė</th>
                        <th>Specializacija</th>
                        <th>Pareigos</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var t in Model.PriskirtiTreneriai)
                    {
                        <tr>
                            <td>@t.Id</td>
                            <td>@t.Vardas</td>
                            <td>@t.Pavarde</td>
                            <td>@t.Specializacija</td>
                            <td>@t.Pareigos</td>
                        </tr>
                    }
                </tbody>
            </table>
        }
        else
        {
            <p>Trenerių dar nepriskirta.</p>
        }
    </div>

    <button type="submit" name="actionType" value="save" class="btn btn-primary">Išsaugoti salės pakeitimus</button>
    <a class="btn btn-secondary" asp-action="Index">Atšaukti</a>
</form>