@model Lab_2_DB.Models.KovosDuomenys
@{
    ViewBag.Title = "Šalinti kovą";
    bool notPermitted = ViewData["deletionNotPermitted"] as bool? ?? false;
}

<h2>Šalinti kovą?</h2>
@if (notPermitted)
{
    <div class="alert alert-danger">Šio įrašo šalinti negalima, nes yra susijusių įrašų.</div>
}
<table class="table">
    <tr><th>ID</th><td>@Model.Id</td></tr>
    <tr><th>Kovos eilė</th><td>@Model.KovosEile</td></tr>
    <tr><th>Laikas</th><td>@Model.KovosLaikasData.ToString("yyyy-MM-dd HH:mm")</td></tr>
</table>
@if (!notPermitted)
{
    <form asp-action="DeleteConfirm" asp-route-id="@Model.Id" method="post">
        <button type="submit" class="btn btn-danger">Taip, pašalinti</button>
        <a class="btn btn-secondary" asp-action="Index">Atšaukti</a>
    </form>
}
else
{
    <a class="btn btn-secondary" asp-action="Index">Grįžti</a>
}
