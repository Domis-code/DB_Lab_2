@model List<Lab_2_DB.Models.SvorioKategorija>
@{
    ViewBag.Title = "Svorio kategorijos";
}

<h2>Svorio kategorijos</h2>

<p><a class="btn btn-success" asp-action="Create">+ Pridėti naują kategoriją</a></p>

<table class="table">
    <thead>
        <tr>
            <th>Id</th>
            <th>Sporto šaka</th>
            <th>Pavadinimas</th>
            <th>Min (kg)</th>
            <th>Maks (kg)</th>
            <th>Amžius nuo</th>
            <th>Lytis</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @if (Model.Count == 0)
        {
            <tr><td colspan="8"><em>Įrašų nėra.</em></td></tr>
        }
        @foreach (var s in Model)
        {
            <tr>
                <td>@s.Id</td>
                <td>@s.SportoSaka</td>
                <td>@s.KategorijosPavadinimas</td>
                <td>@s.MinKg.ToString("0.##")</td>
                <td>@s.MaxKg.ToString("0.##")</td>
                <td>@s.AmziausGrupe</td>
                <td>@(s.LytiesGrupe == 1 ? "Vyras" : "Moteris")</td>
                <td>
                    <a asp-action="Edit" asp-route-id="@s.Id">Redaguoti</a> |
                    <a asp-action="Delete" asp-route-id="@s.Id">Šalinti</a>
                </td>
            </tr>
        }
    </tbody>
</table>


