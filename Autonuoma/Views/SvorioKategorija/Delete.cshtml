@model Lab_2_DB.Models.SvorioKategorija
@{
    ViewBag.Title = "Šalinti kategoriją";
    bool notPermitted = ViewData["deletionNotPermitted"] as bool? ?? false;
}

<h2>Šalinti svorio kategoriją?</h2>

@if (notPermitted)
{
    <div class="alert alert-danger">Šios kategorijos šalinti negalima – ji naudojama kovose.</div>
}

<table class="table">
    <tr><th>Id</th><td>@Model.Id</td></tr>
    <tr><th>Sporto šaka</th><td>@Model.SportoSaka</td></tr>
    <tr><th>Pavadinimas</th><td>@Model.KategorijosPavadinimas</td></tr>
    <tr><th>Svoris</th><td>@Model.MinKg – @Model.MaxKg kg</td></tr>
    <tr><th>Amžius nuo</th><td>@Model.AmziausGrupe</td></tr>
    <tr><th>Lytis</th><td>@(Model.LytiesGrupe == 1 ? "Vyras" : "Moteris")</td></tr>
</table>

@if (!notPermitted)
{
    <form asp-action="DeleteConfirm" asp-route-id="@Model.Id" method="post">
        <button type="submit" class="btn btn-danger">Taip, pašalinti</button>
        <a class="btn btn-secondary" asp-action="Index">Atšaukti</a>
    </form>
}
else
{
    <a class="btn btn-secondary" asp-action="Index">Grįžti</a>
}


