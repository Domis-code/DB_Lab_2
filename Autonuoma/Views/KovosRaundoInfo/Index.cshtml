@model List<Lab_2_DB.Models.KovosRaundoInfo>
@{
    ViewBag.Title = "Kovos raundo info";
}

<h2>Kovos raundo info</h2>
<p><a class="btn btn-success" asp-action="Create">+ Pridėti raundą</a></p>
<table class="table">
    <thead>
        <tr><th>ID</th><th>Kova</th><th>Raundas</th><th>Trukmė</th><th>Pabaiga</th><th></th></tr>
    </thead>
    <tbody>
    @if (Model.Count == 0) { <tr><td colspan="6"><em>Įrašų nėra.</em></td></tr> }
    @foreach (var r in Model)
    {
        <tr>
            <td>@r.Id</td>
            <td>@(r.KovosPavadinimas ?? r.FkKovosDuomenys.ToString())</td>
            <td>@r.RaundoNumeris</td>
            <td>@(r.RaundoTrukmeMin ?? 0):@r.RaundoTrukmeSek.ToString("00")</td>
            <td>@(r.RaundoPabaigaPavadinimas ?? r.RaundoPabaiga.ToString())</td>
            <td><a asp-action="Edit" asp-route-id="@r.Id">Redaguoti</a> | <a asp-action="Delete" asp-route-id="@r.Id">Šalinti</a></td>
        </tr>
    }
    </tbody>
</table>



