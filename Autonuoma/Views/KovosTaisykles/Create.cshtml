@model Lab_2_DB.Models.KovosTaisykles
@{
    ViewBag.Title = "Naujos taisyklės";
}

<h2>Naujos kovos taisyklės</h2>

<form asp-action="Create" method="post">
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

    <div class="form-group">
        <label asp-for="TaisykliuPavadinimas"></label>
        <input asp-for="TaisykliuPavadinimas" class="form-control" />
        <span asp-validation-for="TaisykliuPavadinimas" class="text-danger"></span>
    </div>
    <div class="form-group">
        <label asp-for="RaunduSkaicius"></label>
        <input asp-for="RaunduSkaicius" type="number" class="form-control" />
        <span asp-validation-for="RaunduSkaicius" class="text-danger"></span>
    </div>
    <div class="form-group">
        <label asp-for="RaundoTrukmeMin"></label>
        <input asp-for="RaundoTrukmeMin" type="number" class="form-control" />
        <span asp-validation-for="RaundoTrukmeMin" class="text-danger"></span>
    </div>
    <div class="form-group">
        <label asp-for="KovosTaisykliuTipas"></label>
        <select asp-for="KovosTaisykliuTipas" asp-items="@Model.TaisykliuTipaiList" class="form-control">
            <option value="">-- pasirinkite tipą --</option>
        </select>
        <span asp-validation-for="KovosTaisykliuTipas" class="text-danger"></span>
    </div>
    <div class="form-group">
        <label asp-for="TaskuSistema"></label>
        <select asp-for="TaskuSistema" asp-items="@Model.TaskuSistemaList" class="form-control">
            <option value="">-- pasirinkite sistemą --</option>
        </select>
        <span asp-validation-for="TaskuSistema" class="text-danger"></span>
    </div>

    <button type="submit" class="btn btn-primary">Sukurti</button>
    <a class="btn btn-secondary" asp-action="Index">Atšaukti</a>
</form>