@model Lab_2_DB.Models.Treneris
@{
    ViewBag.Title = "Redaguoti trenerį";
}

<h2>Redaguoti trenerį</h2>

<form asp-action="Edit" asp-route-id="@Model.Id" method="post">
    <input type="hidden" asp-for="Id" />
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

    <div class="form-group">
        <label asp-for="Vardas"></label>
        <input asp-for="Vardas" class="form-control" />
        <span asp-validation-for="Vardas" class="text-danger"></span>
    </div>
    <div class="form-group">
        <label asp-for="Pavarde"></label>
        <input asp-for="Pavarde" class="form-control" />
        <span asp-validation-for="Pavarde" class="text-danger"></span>
    </div>
    <div class="form-group">
        <label asp-for="Specializacija"></label>
        <input asp-for="Specializacija" class="form-control" />
        <span asp-validation-for="Specializacija" class="text-danger"></span>
    </div>
    <div class="form-group">
        <label asp-for="Pareigos"></label>
        <input asp-for="Pareigos" class="form-control" />
        <span asp-validation-for="Pareigos" class="text-danger"></span>
    </div>
    <div class="form-group">
        <label asp-for="PatirtisMetais"></label>
        <input asp-for="PatirtisMetais" type="number" class="form-control" />
        <span asp-validation-for="PatirtisMetais" class="text-danger"></span>
    </div>
    <div class="form-group">
        <label asp-for="FkKovinioSportoSale"></label>
        <select asp-for="FkKovinioSportoSale" asp-items="@Model.SportoSalesList" class="form-control">
            <option value="">-- pasirinkite salę --</option>
        </select>
        <span asp-validation-for="FkKovinioSportoSale" class="text-danger"></span>
    </div>

    <button type="submit" class="btn btn-primary">Išsaugoti</button>
    <a class="btn btn-secondary" asp-action="Index">Atšaukti</a>
</form>


