@model Lab_2_DB.Models.Treneris
@{
    ViewBag.Title = "Šalinti trenerį";
    bool notPermitted = ViewData["deletionNotPermitted"] as bool? ?? false;
}

<h2>Šalinti trenerį?</h2>

@if (notPermitted)
{
    <div class="alert alert-danger">Šio trenerio šalinti negalima – jis susietas su kitais duomenimis.</div>
}

<table class="table">
    <tr><th>Id</th><td>@Model.Id</td></tr>
    <tr><th>Vardas</th><td>@Model.Vardas</td></tr>
    <tr><th>Pavardė</th><td>@Model.Pavarde</td></tr>
    <tr><th>Specializacija</th><td>@Model.Specializacija</td></tr>
    <tr><th>Pareigos</th><td>@Model.Pareigos</td></tr>
    <tr><th>Patirtis (m.)</th><td>@Model.PatirtisMetais</td></tr>
    <tr><th>Sporto salė</th><td>@Model.FkKovinioSportoSale</td></tr>
</table>

@if (!notPermitted)
{
    <form asp-action="DeleteConfirm" asp-route-id="@Model.Id" method="post">
        <button type="submit" class="btn btn-danger">Taip, pašalinti</button>
        <a class="btn btn-secondary" asp-action="Index">Atšaukti</a>
    </form>
}
else
{
    <a class="btn btn-secondary" asp-action="Index">Grįžti</a>
}


