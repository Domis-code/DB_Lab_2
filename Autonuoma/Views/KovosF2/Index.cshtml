@model List<Lab_2_DB.Models.KovosF2.KovaL>
@{
    ViewData["title"] = "Kovos F1";
}

<h2>Kovos (F1)</h2>
<p><a class="btn btn-success" asp-action="Create">+ Nauja kova (F2)</a></p>

<table class="table entity-list">
    <thead>
        <tr>
            <th>ID</th>
            <th>Kovos eilė</th>
            <th>Kovos data</th>
            <th>Titulinė</th>
            <th>Statusas</th>
            <th>Renginys</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
    @if (Model.Count == 0)
    {
        <tr><td colspan="7"><em>Įrašų nėra.</em></td></tr>
    }
    else
    {
        @foreach (var k in Model)
        {
            <tr>
                <td>@k.Id</td>
                <td>@k.KovosEile</td>
                <td>@k.KovosLaikasData.ToString("yyyy-MM-dd HH:mm")</td>
                <td>@k.TitulineKova</td>
                <td>@k.Statusas</td>
                <td>@k.Renginys</td>
                <td>
                    <a asp-action="Edit" asp-route-id="@k.Id">Redaguoti (F2)</a> |
                    <a asp-action="Delete" asp-route-id="@k.Id">Šalinti</a>
                </td>
            </tr>
        }
    }
    </tbody>
</table>



