@model Lab_2_DB.Models.Kovotojas
@{
    ViewBag.Title = "Naujas kovotojas";
}

<h2>Naujas kovotojas</h2>

<form asp-action="Create" method="post">
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

    <div class="form-group">
        <label asp-for="Vardas"></label>
        <input asp-for="Vardas" class="form-control" />
        <span asp-validation-for="Vardas" class="text-danger"></span>
    </div>
    <div class="form-group">
        <label asp-for="Pavarde"></label>
        <input asp-for="Pavarde" class="form-control" />
        <span asp-validation-for="Pavarde" class="text-danger"></span>
    </div>
    <div class="form-group">
        <label asp-for="GimimoData"></label>
        <input asp-for="GimimoData" type="date" class="form-control" />
        <span asp-validation-for="GimimoData" class="text-danger"></span>
    </div>
    <div class="form-group">
        <label asp-for="SvorisKg"></label>
        <input asp-for="SvorisKg" type="number" step="0.01" class="form-control" />
        <span asp-validation-for="SvorisKg" class="text-danger"></span>
    </div>
    <div class="form-group">
        <label asp-for="UgisCm"></label>
        <input asp-for="UgisCm" type="number" class="form-control" />
        <span asp-validation-for="UgisCm" class="text-danger"></span>
    </div>

    <button type="submit" class="btn btn-primary">Sukurti</button>
    <a class="btn btn-secondary" asp-action="Index">Atšaukti</a>
</form>


