<h2>Kovotojai</h2>

<p><a class="btn btn-success" asp-action="Create">+ Pridėti naują kovotoją</a></p>
<p><a class="btn btn-outline-primary" asp-controller="KovosF2" asp-action="Index">Eiti į Kovos F1/F2 formą</a></p>

<table class="table">
    <thead>
        <tr>
            <th>Id</th>
            <th>Vardas</th>
            <th>Pavardė</th>
            <th>Gimimo data</th>
            <th>Svoris (kg)</th>
            <th>Ūgis (cm)</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @if (Model.Count == 0)
        {
            <tr><td colspan="7"><em>Įrašų nėra.</em></td></tr>
        }
        @foreach (var k in Model)
        {
            <tr>
                <td>@k.Id</td>
                <td>@k.Vardas</td>
                <td>@k.Pavarde</td>
                <td>@k.GimimoData.ToString("yyyy-MM-dd")</td>
                <td>@k.SvorisKg.ToString("0.##")</td>
                <td>@(k.UgisCm?.ToString() ?? "—")</td>
                <td>
                    <a asp-action="Edit" asp-route-id="@k.Id">Redaguoti</a>
                    |
                    <a asp-action="Delete" asp-route-id="@k.Id">Šalinti</a>
                </td>
            </tr>
        }
    </tbody>
</table>


