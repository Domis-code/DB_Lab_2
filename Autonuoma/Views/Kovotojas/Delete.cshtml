@model Lab_2_DB.Models.Kovotojas
@{
    ViewBag.Title = "Šalinti kovotoją";
    bool notPermitted = ViewData["deletionNotPermitted"] as bool? ?? false;
}

<h2>Šalinti kovotoją?</h2>

@if (notPermitted)
{
    <div class="alert alert-danger">
        Šio kovotojo šalinti negalima – jis susietas su kovomis ar narystėmis.
        Pirmiausia pašalinkite susijusius įrašus.
    </div>
}

<table class="table">
    <tr><th>Id</th><td>@Model.Id</td></tr>
    <tr><th>Vardas</th><td>@Model.Vardas</td></tr>
    <tr><th>Pavardė</th><td>@Model.Pavarde</td></tr>
    <tr><th>Gimimo data</th><td>@Model.GimimoData.ToString("yyyy-MM-dd")</td></tr>
    <tr><th>Svoris (kg)</th><td>@Model.SvorisKg.ToString("0.##")</td></tr>
    <tr><th>Ūgis (cm)</th><td>@(Model.UgisCm?.ToString() ?? "—")</td></tr>
</table>

@if (!notPermitted)
{
    <form asp-action="DeleteConfirm" asp-route-id="@Model.Id" method="post">
        <button type="submit" class="btn btn-danger">Taip, pašalinti</button>
        <a class="btn btn-secondary" asp-action="Index">Atšaukti</a>
    </form>
}
else
{
    <a class="btn btn-secondary" asp-action="Index">Grįžti į sąrašą</a>
}